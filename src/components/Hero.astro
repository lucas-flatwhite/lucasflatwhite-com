---
import { primaryLinks, siteProfile } from '../data/site';
---

<section class="hero" id="hero" aria-labelledby="hero-title">
  <div class="hero-copy">
    <p class="eyebrow">$ brew --portfolio</p>
    <p>{siteProfile.handle}</p>
    <h1 id="hero-title">{siteProfile.title}</h1>
    <p>{siteProfile.intro}</p>
    <p>{siteProfile.availability}</p>
  </div>

  <div class="hero-actions">
    <div class="hero-links">
      {primaryLinks.map((link) => (
        <a
          class="hero-link"
          href={link.href}
          target={link.external ? '_blank' : undefined}
          rel={link.external ? 'noreferrer' : undefined}
        >
          {link.label}
        </a>
      ))}
    </div>

    <button
      class="coffee-trigger"
      type="button"
      aria-expanded="false"
      aria-controls="command-menu"
    >
      <img src="/assets/flatwhite.svg" alt="" width="20" height="20" />
      <span>Recommended commands</span>
    </button>
  </div>
</section>
