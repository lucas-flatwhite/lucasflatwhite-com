---
import { primaryLinks, siteProfile } from '../data/site';
---

<section class="hero" id="hero" aria-labelledby="hero-title">
  <div class="hero-stage">
    <div class="hero-spinner-wrap" aria-hidden="true">
      <div class="hero-spinner"></div>
    </div>

    <h1 id="hero-title">{siteProfile.heroTitle}</h1>

    <p class="hero-tagline">{siteProfile.heroTagline}</p>
  </div>

  <nav class="hero-actions" aria-label="Hero links">
    <div class="hero-links">
      {primaryLinks.map((link) => (
        <a
          class="hero-link"
          href={link.href}
          target={link.external ? '_blank' : undefined}
          rel={link.external ? 'noreferrer' : undefined}
        >
          {link.label}
        </a>
      ))}
    </div>
  </nav>
</section>
